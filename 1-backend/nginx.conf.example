# === Nginx reverse proxy — 10 GB (5 soatlik video) uchun ===
# MUHIM: bularsiz katta fayl yuklashda 413 (Request Entity Too Large) xatosi chiqadi.

server {
    listen 80;
    server_name api.sizning-domeningiz.uz;

    # 10 GB yuklashga ruxsat (default atigi 1 MB!)
    client_max_body_size 10240m;

    # Katta fayl yuklashda ulanish uzilmasligi uchun timeoutlar
    client_body_timeout      1800s;   # 30 daqiqa
    proxy_read_timeout       1800s;
    proxy_send_timeout       1800s;
    send_timeout             1800s;

    # Katta faylni diskka bufferlamasdan to'g'ridan-to'g'ri uzatish (RAM tejaladi)
    proxy_request_buffering  off;

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}

# HTTPS uchun (Certbot bilan) yuqoridagi bloklarni 443 serverga ham qo'shing.
