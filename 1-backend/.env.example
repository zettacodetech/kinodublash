# === Umumiy ===
APP_NAME="AI Video Dublyaj Backend"
DEBUG=false
BASE_URL="https://api.sizning-domeningiz.uz"

# === PostgreSQL (async) ===
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/dubbing"

# ==========================================================
#  PROVAYDER TANLOVI (dublyaj pipeline har bosqichi uchun)
# ==========================================================
# STT:        faster_whisper | openai_whisper | groq
# TARJIMA:    ollama | groq
# TTS:        edge | openai | coqui | bark | chattts | melotts
STT_PROVIDER=faster_whisper
TRANSLATION_PROVIDER=ollama
TTS_PROVIDER=edge

# === Bulut kalitlari (MAXFIY) ===
GROQ_API_KEY=""
GROQ_API_KEYS=""  # masalan: "gsk_...1,gsk_...2"
OPENAI_API_KEY=""

# --- Groq modellari ---
GROQ_WHISPER_MODEL="whisper-large-v3"
GROQ_LLM_MODEL="llama-3.3-70b-versatile"

# --- OpenAI TTS ---
OPENAI_TTS_MODEL="tts-1"
TTS_VOICE_MALE="onyx"
TTS_VOICE_FEMALE="nova"

# === Ollama (lokal LLM / vision / kod) ===
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_LLM_MODEL="qwen2.5:7b"
OLLAMA_CODE_MODEL="qwen2.5-coder:7b"
OLLAMA_VISION_MODEL="llava:13b"
OLLAMA_TRANSLATE_TIMEOUT_SECONDS=20

# === Lokal Whisper ===
WHISPER_MODEL_SIZE="large-v3"     # large-v3 | medium | small | base
WHISPER_DEVICE="auto"             # cpu | cuda | auto
WHISPER_COMPUTE_TYPE="int8"       # int8 | float16 | float32

# === Edge-TTS (BEPUL, native o'zbek) ===
EDGE_TTS_VOICE_MALE="uz-UZ-SardorNeural"
EDGE_TTS_VOICE_FEMALE="uz-UZ-MadinaNeural"

# === Boshqa lokal TTS ===
COQUI_TTS_MODEL="tts_models/multilingual/multi-dataset/xtts_v2"
COQUI_TTS_LANGUAGE="tr"
MELO_TTS_LANGUAGE="EN"

# === Speaker-aware dublyaj / voice clone reference ===
SPEAKER_REFERENCE_SECONDS=8.0
SPEAKER_REFERENCE_PAD_SECONDS=0.25
MIN_SPEECH_SEGMENT_SECONDS=0.35

# === Embeddings ===
EMBEDDING_MODEL="./models/bge-large"

# === Rasm generatsiya ===
IMAGE_MODEL="./models/sdxl-turbo"
IMAGE_DEVICE="cuda"               # cuda | cpu | mps

# === Vision ===
BLIP_MODEL="./models/blip"

# === Yuklash chegarasi ===
MAX_UPLOAD_MB=5120   # 5 GB
