# BotFather'dan olingan token
BOT_TOKEN="1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Markaziy backend manzili (1-loyiha ishlayotgan server)
BACKEND_URL="https://api.sizning-domeningiz.uz"

# Status tekshirish oralig'i (soniya) va maksimal kutish
POLL_INTERVAL=5
POLL_TIMEOUT=1200

# Telegram bot orqali qabul qilinadigan maksimal video (MB)
# Oddiy Bot API: ~20MB. Lokal Bot API server bilan: 2000MB (2GB) gacha.
MAX_VIDEO_MB=2000

# Lokal Bot API server manzili (masalan http://localhost:8081).
# Bo'sh qoldirilsa rasmiy https://api.telegram.org ishlatiladi.
TELEGRAM_API_URL=
